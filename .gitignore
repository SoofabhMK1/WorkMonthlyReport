# ==========================================
# SIIC Report Agent - GitHub 忽略清单
# ==========================================

# 1. 敏感配置 (最重要！绝对不能上传 API Key)
.env
*.env
.env.*

# 2. 业务原始数据与生成结果 (保护公司医疗/财务隐私)
data/*
!data/.gitkeep
output/*
!output/.gitkeep
debug.html

# 3. Python 虚拟环境 (包含大量依赖，不应上传)
.venv/
venv/
env/

# 4. Python 缓存与编译文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 5. IDE 与编辑器配置文件 (避免不同开发者的环境冲突)
.vscode/
.idea/
*.swp
*.swo

# 6. 操作系统生成的临时文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db